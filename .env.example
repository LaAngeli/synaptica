SMTP_HOST=smtp.hostinger.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=contact@synaptica-cluj.ro
SMTP_PASS=your-mailbox-password

MAIL_FROM=contact@synaptica-cluj.ro
MAIL_TO=contact@synaptica-cluj.ro

CONTACT_ALLOWED_ORIGIN=https://synaptica-cluj.ro,https://www.synaptica-cluj.ro
CONTACT_RATE_LIMIT_WINDOW_MS=900000
CONTACT_RATE_LIMIT_MAX_REQUESTS=5

NEXT_PUBLIC_RECAPTCHA_SITE_KEY=your-recaptcha-site-key
RECAPTCHA_SECRET_KEY=your-recaptcha-secret-key
RECAPTCHA_EXPECTED_ACTION=contact_submit
RECAPTCHA_MIN_SCORE=0.5

# Google reviews (Places API New) — opțional; fără chei, secțiunea afișează recenzii demonstrative
# Cheie server-only, NU o expune client-side.
GOOGLE_PLACES_API_KEY=your-google-places-api-key
GOOGLE_PLACE_ID=your-google-place-id

# Google Maps embed (/contact) — cheie SEPARATĂ de GOOGLE_PLACES_API_KEY de mai sus.
# E publică (NEXT_PUBLIC_), expusă în HTML — restricționeaz-o în Cloud Console la
# "Maps Embed API" + HTTP referrers (synaptica-cluj.ro/*), NICIODATĂ la Places API.
# Fără ea, harta rămâne pe embed-ul gratuit fără cheie (comportamentul actual).
NEXT_PUBLIC_GOOGLE_MAPS_EMBED_KEY=your-google-maps-embed-key
