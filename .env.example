SMTP_HOST=smtp.hostinger.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=contacts@synaptica-cluj.ro
SMTP_PASS=your-mailbox-password

MAIL_FROM=contacts@synaptica-cluj.ro
MAIL_TO=contacts@synaptica-cluj.ro

CONTACT_ALLOWED_ORIGIN=https://synaptica-cluj.ro,https://www.synaptica-cluj.ro
CONTACT_RATE_LIMIT_WINDOW_MS=900000
CONTACT_RATE_LIMIT_MAX_REQUESTS=5

NEXT_PUBLIC_RECAPTCHA_SITE_KEY=your-recaptcha-site-key
RECAPTCHA_SECRET_KEY=your-recaptcha-secret-key
RECAPTCHA_EXPECTED_ACTION=contact_submit
RECAPTCHA_MIN_SCORE=0.5
